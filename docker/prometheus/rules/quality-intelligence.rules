groups:
  - name: btv_quality_intelligence
    rules:
      # Alertas para Pipeline Síncrono (Porteiro Rápido)
      - alert: SyncPipelineFailed
        expr: increase(btv_pipeline_sync_failures_total[5m]) > 0
        for: 2m
        labels:
          severity: critical
          pipeline: sync
        annotations:
          summary: "Pipeline Síncrono (Porteiro Rápido) está falhando"
          description: "O pipeline síncrono falhou {{ $value }} vezes nos últimos 5 minutos. Merge bloqueado."

      # Alertas para Pipeline Assíncrono (Auditor Profundo)
      - alert: AsyncPipelineFailed
        expr: increase(btv_pipeline_async_failures_total[1h]) > 2
        for: 10m
        labels:
          severity: warning
          pipeline: async
        annotations:
          summary: "Pipeline Assíncrono (Auditor Profundo) está falhando"
          description: "O pipeline assíncrono falhou {{ $value }} vezes na última hora. Análises profundas podem estar comprometidas."

      # Alertas para Qualidade do Código
      - alert: MutationTestScoreLow
        expr: btv_mutation_test_score < 85
        for: 15m
        labels:
          severity: warning
          quality_gate: mutation
        annotations:
          summary: "Mutation Test Score abaixo do threshold"
          description: "Mutation test score está em {{ $value }}% (mínimo: 85%). Qualidade da lógica comprometida."

      - alert: FlakyTestRateHigh
        expr: btv_flaky_test_rate > 0.05
        for: 10m
        labels:
          severity: warning
          quality_gate: flaky
        annotations:
          summary: "Taxa de Flaky Tests alta"
          description: "{{ $value }}% dos testes são flaky (máximo: 5%). Confiabilidade do pipeline comprometida."

      - alert: CodeCoverageLow
        expr: btv_code_coverage < 80
        for: 30m
        labels:
          severity: warning
          quality_gate: coverage
        annotations:
          summary: "Code Coverage abaixo do mínimo"
          description: "Code coverage está em {{ $value }}% (mínimo: 80%)."
