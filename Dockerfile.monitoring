FROM alpine:3.18 as exporter-builder

# Instalar dependências para custom exporter
RUN apk add --no-cache python3 py3-pip
RUN pip3 install prometheus-client requests

# Script simulador de métricas do GitHub Actions
COPY scripts/monitoring/github-metrics-simulator.py /app/
RUN chmod +x /app/github-metrics-simulator.py

CMD ["python3", "/app/github-metrics-simulator.py"]

# Exporter real seria implementado aqui
