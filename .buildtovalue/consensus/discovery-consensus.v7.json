  "business_context": {
    "problem_statement": "Pequenos e médios varejistas brasileiros perdem 2-5% da receita em erros de conciliação manual entre vendas (POS/E-commerce) e recebimentos de adquirentes (Cielo, Rede, Stone). Reconciliação manual consome 6-12h/mês e divergências levam 3-6 meses para serem detectadas.",
    "solution": "Sistema agêntico inteligente que automatiza 100% da reconciliação, detecta anomalias em tempo real via ML, prevê fluxo de caixa com 95% de acurácia, e permite recuperar R$ 2-5k/ano por loja com contestações automáticas.",
    "value_proposition": {
      "primary": "Recupere até R$ 5k/ano em cobranças incorretas das adquirentes",
      "secondary": "Economize 8h/mês eliminando reconciliação manual",
      "tertiary": "Preveja fluxo de caixa dos próximos 90 dias com 95% de acurácia"
    },
    "target_users": [
      {
        "persona": "Mariana - E-commerce Owner",
        "profile": "34 anos, loja D2C cosméticos, R$ 120k/mês, não-tech",
        "jtbd": [
          "Descobrir rapidamente se está perdendo dinheiro",
          "Entender o que aconteceu sem jargão técnico",
          "Agir imediatamente para recuperar valores"
        ]
      },
      {
        "persona": "Roberto - Franqueador Multi-Loja",
        "profile": "48 anos, 8 franquias açaí, R$ 600k/mês total",
        "jtbd": [
          "Visão consolidada de todas as lojas",
          "Benchmark entre lojas (qual perde mais dinheiro?)",
          "Auditoria sem contratar analista financeiro"
        ]
      }
    ],
    "competitive_landscape": {
      "existing_solutions": [
        "Equals",
        "Nibo",
        "Conta Azul"
      ],
      "differentiation": [
        "Agentes IA especializados vs UI manual",
        "Detecção proativa de anomalias vs relatórios reativos",
        "Contestação automática vs exportação Excel"
      ]
    },
    "success_metrics": [
      {
        "metric": "Reconciliation Accuracy",
        "target": "99.5%",
        "current": "N/A (MVP)"
      },
      {
        "metric": "Time to Detect Divergence",
