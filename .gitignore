site/
docs/_build/

# Secrets (double check)
*secret*
*password*
*token*
*key*.txt
*.pem
*.key

# Except example files
!.env.example
!config/keys.example.yaml
!src/infrastructure/security/secrets_manager.py
!tests/unit/security/test_password_hasher.py
