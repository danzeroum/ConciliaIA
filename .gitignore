# BuildToValue specific
.buildtovalue/ledger/*
.buildtovalue/chromadb/*
.buildtovalue/logs/*
.buildtovalue/cache/*
.buildtovalue/tmp/*

# Keep structure folders
!.buildtovalue/ledger/.gitkeep
!.buildtovalue/chromadb/.gitkeep
!.buildtovalue/logs/.gitkeep
!.buildtovalue/cache/.gitkeep
!.buildtovalue/tmp/.gitkeep

