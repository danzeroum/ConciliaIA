# Database — copy this file to .env and fill in your own values
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@localhost:5432/YOUR_DB_NAME
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=YOUR_DB_USER
POSTGRES_PASSWORD=YOUR_DB_PASSWORD
POSTGRES_DB=YOUR_DB_NAME

# API
PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=your-random-secret-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900

# AI / LLM integrations (optional)
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
FREE_MODE_ENABLED=true

# Cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Vector store
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Monitoring (optional)
PROMETHEUS_URL=
SLACK_WEBHOOK_URL=

# Acquirer integrations (optional — routes return 503 until configured)
# Cielo Conciliator (Agiliza reports over HTTP, OAuth2 client_credentials)
CIELO_CONCILIATOR_BASE_URL=
CIELO_CONCILIATOR_CLIENT_ID=
CIELO_CONCILIATOR_CLIENT_SECRET=
# CIELO_CONCILIATOR_SCOPE=conciliator.read
# Rede REST API (sales/conciliation, OAuth2 + Bearer)
#   Sandbox base:    https://rl7-sandbox-api.useredecloud.com.br
#   Production base: https://api.userede.com.br/redelabs
REDE_API_BASE_URL=
REDE_CLIENT_ID=
REDE_CLIENT_SECRET=
# REDE_SCOPE=
# Advanced — override only if Rede's docs differ from these defaults:
# REDE_TOKEN_PATH=/oauth/token
# REDE_TRANSACTIONS_PATH=/transactions
