# ====================================
# BuildToValue v7 - Configuration
# ====================================

# ====================================
# DATABASE CONFIGURATION
# ====================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=btv_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=buildtovalue

# ====================================
# REDIS CONFIGURATION
# ====================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================================
# CHROMADB CONFIGURATION
# ====================================
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIRECTORY=./.buildtovalue/chromadb

# ====================================
# LLM API KEYS
# ====================================
# Get your keys at:
# OpenAI: https://platform.openai.com/api-keys
# Anthropic: https://console.anthropic.com/
# Google: https://makersuite.google.com/app/apikey

OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=your-google-key-here

# ====================================
# FOUNDATION CONFIGURATION
# ====================================
# Options: lite, standard, enterprise
FOUNDATION_LEVEL=standard

# ====================================
# SECURITY
# ====================================
# Generate with: openssl rand -hex 32
SECRET_KEY=generate-a-secure-random-key-here
ENCRYPTION_KEY=generate-another-secure-key-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ====================================
# MONITORING
# ====================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_in_production

# ====================================
# LOGGING
# ====================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./.buildtovalue/logs/app.log

# ====================================
# ENVIRONMENT
# ====================================
NODE_ENV=development
DEBUG=false
PYTHONUNBUFFERED=1

# ====================================
# PERFORMANCE
# ====================================
MAX_WORKERS=4
CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=60

# ====================================
# EXTERNAL SERVICES (Optional)
# ====================================
SLACK_WEBHOOK_URL=
SENTRY_DSN=
DATADOG_API_KEY=

# ====================================
# DEVELOPMENT (Optional)
# ====================================
HOT_RELOAD=true
AUTO_MIGRATE=true
SEED_DATABASE=false
