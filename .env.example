# Database
DATABASE_URL=postgresql+asyncpg://btv_user:btv_password@localhost:5432/conciliaai

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# Security - JWT
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security - Password
PASSWORD_HASH_ROUNDS=12
MIN_PASSWORD_LENGTH=8

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Multi-tenancy
DEFAULT_RATE_LIMIT=100

# Matching
FUZZY_AMOUNT_TOLERANCE=0.50
FUZZY_DATE_TOLERANCE_DAYS=1
ML_MODEL_PATH=models/matching_model.pkl

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true

# Session
SESSION_SECRET=your-session-secret-change-in-production
